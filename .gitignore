# Local state (user projects get their own .omao/)
.omao-local/
.claude/settings.local.json

# OMA runtime state — PII, verbatim prompts, approval logs, cost data,
# compiled triggers, audit events, enterprise-status archives, etc.
# audit-trail captures user input verbatim (SOC2/ISMS-P retention);
# incident-response stores alarm payloads (may include account IDs, ARNs);
# cost dirs hold per-agent Cost Explorer exports and override overrides.
# The entire .omao/ directory is user-project local — never commit it.
# Files such as triggers.json / status.json / audit.jsonl regenerate
# via `oma compile --all`, `oma enterprise-status`, and
# `tools.oma_audit.append` respectively, so losing them is cheap.
.omao/
**/.omao/

# OMC runtime state (session-specific, never committed)
.omc/
**/.omc/

# Test fixtures
evals/_runs/

# Claude Code per-plugin .claude-plugin/ directories inside plugins/ are
# tracked (they carry plugin.json manifests). The top-level .claude-plugin/
# marketplace.json at repo root is also tracked because the marketplace
# definition is a distributable asset. Historical entries that
# wholesale-ignored this directory have been removed.

# Release artifacts (regenerated by scripts/dev/make-tarball.sh)
dist/

# (Previously ignored .github/workflows/ while mirroring to GitLab.
# Now published via aws-samples on GitHub — workflows are tracked.)

# CLAUDE.md is local-only per top-level rule in CLAUDE.md; never tracked
CLAUDE.md
**/CLAUDE.md

# .omao/profile.yaml — OMA project configuration (schema v1).
# Generated by `oma setup`. Hand-edit at your own risk — run `oma doctor`
# after any change to revalidate.
version: 1
created_at: "{{CREATED_AT}}"

harness:
  primary: {{HARNESS_PRIMARY}}
  secondary: {{HARNESS_SECONDARY}}

aws:
  account_id: "{{AWS_ACCOUNT_ID}}"
  region: {{AWS_REGION}}
  profile_name: {{AWS_PROFILE_NAME}}
  environment: {{AWS_ENVIRONMENT}}

aidlc:
  entry_phase: {{AIDLC_ENTRY_PHASE}}
  strict_gates: {{AIDLC_STRICT_GATES}}

approval:
  mode: {{APPROVAL_MODE}}
  blast_radius_ceiling: {{APPROVAL_BLAST_RADIUS}}

budgets:
  default_monthly_usd: {{BUDGET_MONTHLY_USD}}
  warn_at_pct: {{BUDGET_WARN_PCT}}
  block_at_pct: {{BUDGET_BLOCK_PCT}}

observability:
  mode: {{OBSERVABILITY_MODE}}
  endpoint: {{OBSERVABILITY_ENDPOINT}}

star_confirmed: {{STAR_CONFIRMED}}
